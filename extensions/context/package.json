{
  "name": "@piex-dev/context",
  "version": "0.1.0",
  "type": "module",
  "description": "Context usage report extension for pi — /context command showing session entry distribution and estimated token usage breakdown",
  "license": "MIT",
  "author": "debugtalk",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piex-dev/piex.git",
    "directory": "extensions/context"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "context",
    "context-usage",
    "token-usage",
    "session-stats"
  ],
  "pi": {
    "extensions": [
      "./src/context.ts"
    ]
  },
  "exports": {
    ".": "./src/context.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  }
}
