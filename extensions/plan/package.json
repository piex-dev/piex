{
  "name": "@piex-dev/plan",
  "version": "0.2.0",
  "type": "module",
  "description": "Plan Mode extension for pi — read-only exploration, plan creation, and step-by-step execution with progress tracking",
  "license": "MIT",
  "author": "debugtalk",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piex-dev/piex.git",
    "directory": "extensions/plan"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "plan",
    "plan-mode",
    "todo",
    "execution-tracking"
  ],
  "pi": {
    "extensions": [
      "./src/plan.ts"
    ]
  },
  "exports": {
    ".": "./src/plan.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "typebox": "*"
  }
}
